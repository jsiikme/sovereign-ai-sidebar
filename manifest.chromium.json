{
  "manifest_version": 3,
  "name": "Euria Everywhere (Unofficial)",
  "version": "1.4.0",
  "description": "Unofficial extension: summarize, extract key points, look up a term and translate any web page via Infomaniak's AI API — data stays in Europe. Not affiliated with Infomaniak.",
  "minimum_chrome_version": "116",
  "icons": {
    "48": "icons/euria-48.png",
    "128": "icons/euria-128.png"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.infomaniak.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Euria Everywhere (Unofficial)",
    "default_icon": {
      "48": "icons/euria-48.png",
      "128": "icons/euria-128.png"
    }
  },
  "commands": {
    "toggle-panel": {
      "suggested_key": { "default": "Alt+Shift+E" },
      "description": "Open/close the Euria panel"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
